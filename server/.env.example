PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# =============================================================================
# СОЗДАЙТЕ ЭТОТ ФАЙЛ У СЕБЯ:  cp .env.example .env
# НЕ копируйте чужой .env — там чужая почта и чужой ngrok!
# Файл .env в Git не попадает (.gitignore).
# Подробная инструкция: ../docs/setup-env-db-ngrok.md
# =============================================================================

# --- Почта (СВОЙ ящик — для подтверждения регистрации) ---
# Без SMTP коды выводятся в консоль сервера (для демо достаточно).

# Способ 1: Gmail (рекомендуется)
# Пароль приложения: https://myaccount.google.com/apppasswords
# (обычный пароль Gmail НЕ подойдёт)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=your@gmail.com

# Способ 2: Yandex
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@yandex.ru
# SMTP_PASS=пароль_приложения
# MAIL_FROM=your@yandex.ru

# Способ 3: Resend (https://resend.com — бесплатный тариф)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=onboarding@resend.dev

WEBHOOK_KEY=

# --- Публичная ссылка (СВОЙ ngrok — см. docs/setup-env-db-ngrok.md) ---
# 1) ngrok.com → регистрация
# 2) ngrok config add-authtoken ВАШ_ТОКЕН
# 3) при npm start появится ссылка и QR в терминале
AUTO_NGROK=1
